@model FitForge.Models.ActiveWorkoutVM
@{ ViewData["Title"]="Active Workout"; ViewData["Page"]="Workouts"; }

<div class="active-header">
  <div class="active-header-left">
    <div class="active-title">@Model.DayName</div>
    <div class="active-sub text-muted">@Model.ProgramName</div>
  </div>
  <div class="active-header-right">
    <div class="active-timer" id="elapsed">00:00</div>
    <div class="active-sets-pill" id="sets-done-pill">0/@Model.Exercises.Sum(e=>e.TargetSets)</div>
  </div>
</div>

<div class="session-progresswrap">
  <div class="session-progressbar"><div class="fill" id="session-fill"></div></div>
  <div class="cap"><span id="session-cap">0 of @Model.Exercises.Sum(e=>e.TargetSets) sets logged</span><span id="session-pct">0%</span></div>
</div>

<div id="exercise-list">
  @foreach(var ex in Model.Exercises){
    <div class="exrow" id="ex-@ex.PdeId" data-pde="@ex.PdeId">
      <div class="exrow-main" onclick="openSetSheet(@ex.PdeId)">
        <div class="exicon">
          <img src="/images/exercises/@(ex.ExerciseId).gif" onerror="this.onerror=null;this.src='/images/exercises/@(ex.ExerciseId).svg';this.onerror=function(){this.style.display='none';this.nextElementSibling.style.display='flex';}" loading="lazy"/>
          <div class="ex-thumb-fallback" style="display:none">💪</div>
        </div>
        <div class="exmeta">
          <div class="n">@ex.ExerciseName @if(ex.IsFlagged){<span title="@ex.FlagReason">⚠️</span>}</div>
          <div class="s">
            @ex.TargetSets × @if(ex.TrackDuration){<span>@ex.TargetReps s</span>}else{<span>@ex.TargetReps reps</span>}
            @if(ex.TargetWeight.HasValue){<span> @@ @(ex.TargetWeight)kg</span>}
          </div>
        </div>
        <div class="exsets" id="dots-@ex.PdeId">
          @for(int s=1;s<=ex.TargetSets;s++){<span class="setdot" id="dot-@(ex.PdeId)-@s"></span>}
        </div>
        <div class="chev" id="chev-@ex.PdeId">›</div>
      </div>

      @if(ex.IsFlagged){
        <div class="exrow-flagnote">
          <span>🩹 @ex.FlagReason</span>
          @if(ex.AlternativeId.HasValue){
            <button class="btn btn-sm" onclick="event.stopPropagation();swapExercise(@ex.PdeId,@ex.AlternativeId,'@ex.AlternativeName')">💡 Use @ex.AlternativeName</button>
          }
        </div>
      }

      <div class="exrow-restbar" id="rest-@ex.PdeId" style="display:none">
        <span class="rb-txt" id="rest-count-@ex.PdeId">90</span>
        <div class="rb-track"><div class="rb-fill" id="rest-fill-@ex.PdeId" style="width:100%"></div></div>
        <button class="rb-skip" onclick="skipRest(@ex.PdeId)">skip</button>
      </div>
    </div>
  }
</div>

<!-- Reusable bottom sheet: rep stepper / rest view -->
<div class="ff-sheet-backdrop" id="ff-sheet-backdrop" onclick="if(event.target===this)closeSetSheet()">
  <div class="ff-sheet" id="ff-sheet">
    <div class="ff-sheet-handle"></div>

    <div id="ff-sheet-log">
      <div class="ff-sheet-head">
        <div>
          <div class="eyebrow" id="ff-sheet-target">TARGET</div>
          <div class="n" id="ff-sheet-name">Exercise</div>
        </div>
        <div class="setno" id="ff-sheet-setno">SET 1/1</div>
      </div>
      <div class="ff-last-time" id="ff-last-time" style="display:none"></div>

      <div class="ff-stepper">
        <div class="ff-stepbtn" onclick="stepRep(-1)">–</div>
        <div class="ff-repnum" id="ff-rep-count">0</div>
        <div class="ff-stepbtn" onclick="stepRep(1)">+</div>
      </div>
      <div class="ff-repcap" id="ff-rep-cap">reps completed</div>

      <div class="ff-fieldrow" id="ff-weight-row">
        <div class="ff-field">
          <div class="flbl">Weight (kg)</div>
          <input type="number" class="fval" id="ff-weight-input" placeholder="Bodyweight" step="0.5" min="0"/>
        </div>
        <div class="ff-field">
          <div class="flbl">Rest Next</div>
          <div class="fval" id="ff-rest-preview">90s</div>
        </div>
      </div>

      <div class="ff-rpewrap">
        <div class="ff-rpe-head"><span>Effort · RPE</span><b id="ff-rpe-val">7</b></div>
        <input type="range" min="1" max="10" value="7" id="ff-rpe-slider" oninput="document.getElementById('ff-rpe-val').textContent=this.value">
      </div>

      <div style="display:flex; gap:8px;">
        <button class="btn btn-outline" onclick="skipCurrentSet()">Skip Set</button>
        <button class="btn btn-solid" style="flex:1" onclick="logCurrentSet()">✓ Log Set</button>
      </div>
    </div>

    <div id="ff-sheet-rest" style="display:none">
      <div class="ff-rest-view">
        <div class="eyebrow">RESTING</div>
        <div class="n" id="ff-rest-exname" style="margin-bottom:4px;">Exercise</div>
        <div class="ff-rest-ring">
          <svg viewBox="0 0 100 100">
            <circle class="ff-rest-ring-bg" cx="50" cy="50" r="42"></circle>
            <circle class="ff-rest-ring-fg" id="ff-rest-arc" cx="50" cy="50" r="42"></circle>
          </svg>
          <div class="ff-rest-ring-center">
            <div class="lbl">SECONDS</div>
            <div class="num" id="ff-rest-num">90</div>
          </div>
        </div>
        <button class="btn btn-outline w-100" onclick="skipRestInSheet()">Skip Rest → Next Set</button>
      </div>
    </div>
  </div>
</div>

<div class="active-finish-bar">
  <div class="active-finish-inner">
    <textarea id="session-notes" rows="1" placeholder="Session notes…"></textarea>
    <button class="btn btn-solid finish-btn" id="finish-btn" onclick="finishSession()">✓ Finish</button>
  </div>
</div>

@section Scripts {
<script>
var SESSION_ID = @Model.SessionId;
var DAY_ID     = @Model.DayId;
var EXERCISES  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    Model.Exercises.Select(ex => new {
      pdeId = ex.PdeId, exerciseId = ex.ExerciseId, name = ex.ExerciseName,
      sets = ex.TargetSets, targetReps = ex.TargetReps, restSeconds = ex.RestSeconds,
      trackDuration = ex.TrackDuration, trackWeight = ex.TrackWeight,
      targetWeight = ex.TargetWeight, notes = ex.Notes,
      lastReps = ex.LastReps, lastWeightKg = ex.LastWeightKg,
      lastDate = ex.LastDate.HasValue ? ex.LastDate.Value.ToString("MMM d") : null
    }),
    new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

var exMap = {};
EXERCISES.forEach(function(e){ exMap[e.pdeId] = e; e.doneSets = 0; e.exerciseId2 = e.exerciseId; });

var loggedSets = [];
var doneCount  = 0;
var totalSets  = EXERCISES.reduce(function(a,e){ return a+e.sets; }, 0);
var startTime  = Date.now();
var restTimers = {};
var currentPde = null, currentSet = null, currentRepVal = 0;

// ── Crash-safe draft (recovers logged sets if the page reloads mid-session) ──
function saveDraft(){
  try{
    localStorage.setItem('ff-draft-' + SESSION_ID, JSON.stringify({
      loggedSets: loggedSets, doneCount: doneCount,
      notes: document.getElementById('session-notes').value
    }));
  }catch(e){}
}
function clearDraft(){ try{ localStorage.removeItem('ff-draft-' + SESSION_ID); }catch(e){} }
function restoreDraft(){
  var raw;
  try{ raw = localStorage.getItem('ff-draft-' + SESSION_ID); }catch(e){ return; }
  if(!raw) return;
  try{
    var draft = JSON.parse(raw);
    if(!draft.loggedSets || !draft.loggedSets.length) return;
    loggedSets = draft.loggedSets;
    doneCount  = draft.doneCount || loggedSets.length;
    if(draft.notes) document.getElementById('session-notes').value = draft.notes;
    loggedSets.forEach(function(s){
      var ex = exMap[s.pdeId];
      if(!ex) return;
      ex.doneSets = (ex.doneSets || 0) + 1;
      var dot = document.getElementById('dot-' + s.pdeId + '-' + s.setNumber);
      if(dot) dot.classList.add(s.skipped ? 'skip' : 'on');
    });
    Object.keys(exMap).forEach(function(pdeId){
      var ex = exMap[pdeId];
      if(ex.doneSets >= ex.sets){
        var row = document.getElementById('ex-' + pdeId);
        if(row) row.classList.add('complete');
        var chev = document.getElementById('chev-' + pdeId);
        if(chev) chev.textContent = '✓';
      }
    });
    updateProgress();
    showStackToast('↩️ Recovered ' + loggedSets.length + ' set' + (loggedSets.length===1?'':'s') + ' from before', 'success', 3200);
  }catch(e){}
}
restoreDraft();

// ── Elapsed timer ────────────────────────────────────────────
setInterval(function(){
  var sec = Math.floor((Date.now() - startTime) / 1000);
  var m = Math.floor(sec/60).toString().padStart(2,'0');
  var s = (sec % 60).toString().padStart(2,'0');
  document.getElementById('elapsed').textContent = m + ':' + s;
}, 1000);

function updateProgress(){
  document.getElementById('sets-done-pill').textContent = doneCount + '/' + totalSets;
  document.getElementById('session-cap').textContent = doneCount + ' of ' + totalSets + ' sets logged';
  var pct = totalSets > 0 ? Math.round(doneCount / totalSets * 100) : 0;
  document.getElementById('session-fill').style.width = pct + '%';
  document.getElementById('session-pct').textContent = pct + '%';
}

// ── Sheet: open for next pending set of an exercise ───────────
function openSetSheet(pdeId){
  var ex = exMap[pdeId];
  if(!ex) return;
  if(ex.doneSets >= ex.sets){ return; } // exercise already complete
  currentPde = pdeId;
  currentSet = ex.doneSets + 1;
  currentRepVal = ex.targetReps;

  document.getElementById('ff-sheet-log').style.display = '';
  document.getElementById('ff-sheet-rest').style.display = 'none';
  document.getElementById('ff-sheet-name').textContent = ex.name;
  document.getElementById('ff-sheet-target').textContent = 'TARGET · ' + ex.targetReps + (ex.trackDuration ? ' SEC' : ' REPS');
  document.getElementById('ff-sheet-setno').textContent = 'SET ' + currentSet + '/' + ex.sets;
  document.getElementById('ff-rep-count').textContent = currentRepVal;
  document.getElementById('ff-rep-cap').textContent = ex.trackDuration ? 'seconds held' : 'reps completed';
  document.getElementById('ff-weight-row').style.display = ex.trackDuration ? 'none' : 'flex';
  document.getElementById('ff-weight-input').value = ex.targetWeight || '';
  document.getElementById('ff-weight-input').placeholder = ex.targetWeight ? '' : 'Bodyweight';
  document.getElementById('ff-rest-preview').textContent = ex.restSeconds + 's';
  document.getElementById('ff-rpe-slider').value = 7;
  document.getElementById('ff-rpe-val').textContent = 7;

  var lastEl = document.getElementById('ff-last-time');
  if(ex.lastReps){
    var parts = ex.trackDuration ? (ex.lastReps + 's') : (ex.lastReps + ' reps');
    if(ex.lastWeightKg) parts += ' @@ ' + ex.lastWeightKg + 'kg';
    lastEl.innerHTML = '⏱ Last time: <b>' + parts + '</b>' + (ex.lastDate ? ' · ' + ex.lastDate : '');
    lastEl.style.display = 'inline-flex';
  } else {
    lastEl.style.display = 'none';
  }

  document.getElementById('ff-sheet-backdrop').classList.add('show');
}
function closeSetSheet(){
  document.getElementById('ff-sheet-backdrop').classList.remove('show');
}
function stepRep(d){
  currentRepVal = Math.max(0, currentRepVal + d);
  document.getElementById('ff-rep-count').textContent = currentRepVal;
}

function skipCurrentSet(){ commitCurrentSet(true); }
function logCurrentSet(){ commitCurrentSet(false); }

function commitCurrentSet(skipped){
  var pdeId = currentPde, setNum = currentSet;
  var ex = exMap[pdeId];
  var weight = ex.trackWeight ? (parseFloat(document.getElementById('ff-weight-input').value) || null) : null;
  var rpe = skipped ? null : parseInt(document.getElementById('ff-rpe-slider').value);
  var reps = skipped ? 0 : currentRepVal;

  var dot = document.getElementById('dot-' + pdeId + '-' + setNum);
  if(dot) dot.classList.add(skipped ? 'skip' : 'on');

  loggedSets = loggedSets.filter(function(s){ return !(s.pdeId == pdeId && s.setNumber == setNum); });
  loggedSets.push({ pdeId: parseInt(pdeId), exerciseId: parseInt(ex.exerciseId), setNumber: setNum,
    targetReps: ex.targetReps, actualReps: reps, weightKg: weight, rpe: rpe, skipped: skipped });

  ex.doneSets++;
  doneCount++;
  updateProgress();
  saveDraft();

  if(!skipped && typeof ffConfetti === 'function') ffConfetti(document.getElementById('ex-'+pdeId));

  var exerciseDone = ex.doneSets >= ex.sets;
  if(exerciseDone){
    document.getElementById('ex-'+pdeId).classList.add('complete');
    document.getElementById('chev-'+pdeId).textContent = '✓';
  }

  if(doneCount === totalSets){
    closeSetSheet();
    setTimeout(function(){
      document.querySelector('.active-finish-bar')?.scrollIntoView({ behavior:'smooth', block:'end' });
      showStackToast('🎉 All sets done! Finish when ready.', 'success', 3000);
    }, 300);
    return;
  }

  if(!skipped && !exerciseDone){
    startRest(pdeId, ex.restSeconds, ex.name);
  } else if(exerciseDone){
    closeSetSheet();
  } else {
    // skipped but not last set — advance sheet straight to next set
    openSetSheet(pdeId);
  }
}

// ── Rest timer (row bar + sheet ring, kept in sync) ───────────
function startRest(pdeId, total, exName){
  var row = document.getElementById('ex-'+pdeId);
  var bar = document.getElementById('rest-'+pdeId);
  var countEl = document.getElementById('rest-count-'+pdeId);
  var fillEl  = document.getElementById('rest-fill-'+pdeId);
  row.classList.add('resting');
  bar.style.display = 'flex';

  // switch sheet to rest view
  document.getElementById('ff-sheet-log').style.display = 'none';
  document.getElementById('ff-sheet-rest').style.display = '';
  document.getElementById('ff-rest-exname').textContent = exName;
  var RADIUS = 42, CIRC = 2*Math.PI*RADIUS;
  var arc = document.getElementById('ff-rest-arc');
  arc.style.strokeDasharray = CIRC;
  arc.style.strokeDashoffset = 0;
  document.getElementById('ff-sheet-backdrop').classList.add('show');

  var remaining = total;
  if(restTimers[pdeId]) clearInterval(restTimers[pdeId]);
  restTimers[pdeId] = setInterval(function(){
    remaining--;
    if(countEl) countEl.textContent = Math.max(remaining,0);
    if(fillEl)  fillEl.style.width = Math.max(remaining/total*100,0) + '%';
    document.getElementById('ff-rest-num').textContent = Math.max(remaining,0);
    arc.style.strokeDashoffset = CIRC * (1 - Math.max(remaining,0)/total);
    if(remaining <= 3 && remaining > 0){
      showStackToast('⏱ Rest ending in ' + remaining + 's…', '', 1200);
      if(navigator.vibrate) navigator.vibrate(60);
      ffBeep(440, 90);
    }
    if(remaining <= 0){ finishRest(pdeId, true); }
  }, 1000);
}
function finishRest(pdeId, natural){
  if(restTimers[pdeId]) clearInterval(restTimers[pdeId]);
  var row = document.getElementById('ex-'+pdeId);
  row.classList.remove('resting');
  document.getElementById('rest-'+pdeId).style.display = 'none';
  showStackToast('💥 Rest over — next set!', 'success', 1800);
  if(natural){
    if(navigator.vibrate) navigator.vibrate([120,60,120]);
    ffBeep(660, 180);
  }
  if(currentPde === pdeId){ openSetSheet(pdeId); }
  else { closeSetSheet(); }
}
function skipRest(pdeId){ finishRest(pdeId, false); }
function skipRestInSheet(){ if(currentPde != null) finishRest(currentPde, false); }

// ── Swap flagged exercise ─────────────────────────────────────
function swapExercise(pdeId, altId, altName){
  if(!confirm('Replace with ' + altName + '?')) return;
  var ex = exMap[pdeId];
  ex.exerciseId = altId; ex.name = altName;
  var row = document.getElementById('ex-'+pdeId);
  row.querySelector('.n').childNodes[0].textContent = altName + ' ';
  var note = row.querySelector('.exrow-flagnote');
  if(note) note.remove();
  showStackToast('Swapped to ' + altName, 'success');
}

// ── Finish session ────────────────────────────────────────────
function finishSession(){
  if(loggedSets.length === 0 && !confirm('No sets logged. Finish anyway?')) return;
  var btn = document.getElementById('finish-btn');
  btn.disabled = true; btn.textContent = 'Saving…';
  var notes = document.getElementById('session-notes').value;
  fetch('/Dashboard/FinishSession', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ sessionId: SESSION_ID, dayId: DAY_ID, sets: loggedSets, notes: notes })
  }).then(function(r){ return r.json(); }).then(function(d){
    if(d.success){
      clearDraft();
      if(d.newAchievements && d.newAchievements.length > 0){
        ffConfetti();
        showAchievements(d.newAchievements);
        setTimeout(function(){ window.location = '/Dashboard/Index'; }, d.newAchievements.length * 3500 + 500);
      } else if(d.newPRs && d.newPRs.length > 0){
        ffConfetti();
        showStackToast('🏆 PR: ' + d.newPRs.join(', '), 'success', 3000);
        setTimeout(function(){ window.location = '/Dashboard/Index'; }, 1800);
      } else {
        showStackToast('Session saved! 💪', 'success', 2000);
        setTimeout(function(){ window.location = '/Dashboard/Index'; }, 1200);
      }
    } else {
      btn.disabled = false; btn.textContent = '✓ Finish';
      showStackToast('Error saving session — try again.', 'danger');
    }
  }).catch(function(){
    btn.disabled = false; btn.textContent = '✓ Finish';
    showStackToast('Network error', 'danger');
  });
}
</script>
}
